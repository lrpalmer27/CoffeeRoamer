		padding: auto;
		text-align: center;
	}

	.coffee-wheel-element{
		display: flex;
		flex-wrap: wrap;
		width: 100%;
		max-width: 960px;
		border: 1px solid;
		border-color: var(--black);
		border-radius: 1em;
		box-shadow: var(--box-shadow);
	}

	.h3{ 
		text-align: center;
	}
	
	#flavor-wheel-template--19380736032923__flavor_wheel_prod_clk_2_nRerME{
      --bg:#fff; --ink:#191919; --ring:#e5e7eb; --card:#f7f7f5;
      --c-green: #299246;
      --c-sour: #C7D23A;
      --c-fruity: #DA1625;
      --c-floral: #EC4A9A;
      --c-sweet: #EEB604;
      --c-nutty: #C49A6C;
      --c-spice: #C75B3C;
      --c-roasted: #8D6E63;
      --c-other: #00A2B6;
    }

    #flavor-wheel-template--19380736032923__flavor_wheel_prod_clk_2_nRerME *{ box-sizing:border-box }
    .fw-wrap{ padding:20px; color:var(--ink); font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Inter, Roboto, Arial }
    .fw-hdr{ display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between }
    .fw-hdr h2{ margin:0; font-size:clamp(20px,3vw,28px); font-weight:700 }
    .fw-tools{ display:flex; flex-wrap:wrap; gap:10px; align-items:center }
    .fw-input{ border:1px solid var(--ring); border-radius:12px; padding:10px 12px; min-width:220px; font-size:14px; background:#fff }
    .fw-btn{ border:1px solid var(--ring); background:#ededed; border-radius:999px; padding:8px 12px; font-size:13px; cursor:pointer }
    .fw-btn[aria-pressed="true"]{ background:#111; color:#fff; border-color:#111 }

    /* Square wheel container */
    .fw-canvas{ width:100%; aspect-ratio:1/1; min-width:300px}
