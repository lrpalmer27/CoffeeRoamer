    .seg[aria-selected="true"]{ stroke:#111; stroke-width:1.5 }
    .muted{ opacity:.18 }
    .lbl{ fill:var(--ink); font-weight:600; pointer-events:none }
    .legend{ display:flex; flex-wrap:wrap; gap:8px; margin-top:8px }
    .legend .item{ display:flex; gap:8px; align-items:center; border:1px solid var(--ring); background:#fff; border-radius:12px; padding:6px 10px; font-size:12px }
    .legend .sw{ width:14px; height:14px; border-radius:4px; border:1px solid rgba(0,0,0,.1) }

	.fw-tip{ position:fixed; z-index:30; opacity:0; pointer-events:none; transform:translate(-50%,-120%); background:#111; color:#fff; padding:6px 9px; border-radius:8px; font-size:12px }

	/* Layout + min-width guards */
    .fw-grid{ display:grid; grid-template-columns:minmax(320px,1.2fr) minmax(280px,.8fr); gap:20px; margin-top:14px;}
