---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
        <Header />
        <main>
            <h2> Welcome Coffee Roamers! </h2>
            <p> 
                This site serves as a repository of fun coffee spots that I visit.
                I try to review each for future reference for myself and others. 
                I hope you enjoy!
            </p>

        </main>
        <Footer />
    </body>
</html>
