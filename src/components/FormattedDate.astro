---
interface Props {
	date: Date;
	format?: 'full' | 'short';
}

const { date, format = 'full' } = Astro.props;
---

<time datetime={date.toISOString()}>
	{
		format === 'full'
			? date.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric',})
			: date.toLocaleDateString('en-us', { month:'numeric', day:'numeric', year:'numeric' })
	}
</time>