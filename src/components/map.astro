---
import "maplibre-gl/dist/maplibre-gl.css";
import maplibregl from "maplibre-gl";
import {BASE} from '../consts.ts';

import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const orderedPosts = posts.map(post=>({
  id: post.id,
  coords: post.data.coords,
  title: post.data.title,
  description: post.data.description,
}));

---

<div id="map" 
  style="width:100%; height:600px;"
></div>

<script define:vars={{orderedPosts, BASE}}>
  // console.log("coords var ->",orderedPosts.coords);
  window.addEventListener("DOMContentLoaded", () => {
    const map = new maplibregl.Map({
      container: "map",
      // style: "https://demotiles.maplibre.org/style.json", // testing demo tile
      style: `${BASE}mapstyle.json`,
      attributionControl: false,

      // -------------------- center on north america, roughly --------------------
      // center: [-100,48],
      // zoom: 2.5,
      // --------------------

      // -------------------- center on southbay --------------------
      center: [-118.37000311225792,33.8519980151288],
      zoom: 9.5,
      // --------------------
    });
    
    map.addControl(new maplibregl.NavigationControl());
    
    const features = orderedPosts.map(c => ({
      "type": "Feature",
      "geometry": {
        "type": "Point",
        "coordinates": [c.coords[1], c.coords[0]]
        }, // this is changing from latlong to longlat
      "properties": { "name": c.title, "id":c.id},
    }));
    
    map.on("load",() => {
      map.addSource('CoffeeCoordinates',{
        type: 'geojson',
        data: {
            "type": "FeatureCollection",
            "features": features
          }
      });


      const svg1 = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                    <path fill="#ae3c3c" d="M12 11.5A2.5 2.5 0 0 1 9.5 9A2.5 2.5 0 0 1 12 6.5A2.5 2.5 0 0 1 14.5 9a2.5 2.5 0 0 1-2.5 2.5M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7" />
                    </svg>`;

     const img = new Image();
      img.onload = () => {
        map.addImage('locationIcon', img);
        };
      img.onerror = e => console.error('SVG load error', e);

      img.src = "data:image/svg+xml;charset=utf-8," + encodeURIComponent(svg1);

      map.addLayer({
          'id': 'coffee-points',
          'type': 'symbol',
          'source': 'CoffeeCoordinates',
          'layout':{
            'icon-image':'locationIcon',
            'icon-size': 1,
            'icon-allow-overlap': false
          }
      });

    });


    let popup = new maplibregl.Popup({
      closeButton: true,
      closeOnClick: true
    });

    map.on("mouseenter", "coffee-points", (e) => {
      map.getCanvas().style.cursor = "pointer"; // change cursor
      const feature = e.features[0]; // The clicked feature

      popup
        .setLngLat(feature.geometry.coordinates)
        .setHTML(`<a href=${BASE}posts/${feature.properties.id}> ${feature.properties.name}</a>`)
        .addTo(map);
    });

  });
</script>